# Copy to .env.local — required for the app to run (no mock-data mode)

# Supabase (required)

# Anthropic — English subtitle correction + AI notes
ANTHROPIC_API_KEY=
# Optional: Haiku for /api/claude/correct (default claude-haiku-4-5)
# ANTHROPIC_MODEL=claude-haiku-4-5
# Optional: Sonnet for /api/claude/notes (default claude-sonnet-4-20250514)
# ANTHROPIC_NOTES_MODEL=claude-sonnet-4-20250514

# Google Cloud Translation — Live tab subtitles only
GOOGLE_TRANSLATE_API_KEY=

# Supabase Realtime
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Event
NEXT_PUBLIC_EVENT_ID=biblical-worldview-2026

# Optional: fixed URL for student join QR when presenter uses localhost
# NEXT_PUBLIC_APP_URL=https://sphere-notes-live.vercel.app

# Optional: tighten presenter writes via server routes (Step 2+)
# PRESENTER_SECRET=
